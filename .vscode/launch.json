{
  "configurations": [
    {
      "name": "hello-vite",
      "type": "node",
      "request": "attach",
      "websocketAddress": "ws://localhost:9229/hello-vite",
      "resolveSourceMapLocations": null,
      "attachExistingChildren": false,
      "autoAttachChildProcesses": false,
      "sourceMaps": true
    },
    {
      "name": "Debug Client (Chrome)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}",
      "sourceMaps": true
    }
  ],
  "compounds": [
    {
      "name": "Debug Full Stack (Chrome)",
      "configurations": ["hello-vite", "Debug Client (Chrome)"],
      "stopAll": true,
      "preLaunchTask": "dev"
    }
  ]
}
