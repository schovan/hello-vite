{
  "name": "hello-vite",
  "compatibility_date": "2026-05-08",
  "main": "./worker/index.ts",
  "assets": {
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"]
  },
  "durable_objects": {
    "bindings": [
      { "name": "COUNTER_DO", "class_name": "CounterDO" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["CounterDO"] }
  ]
}
